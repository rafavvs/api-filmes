{
  "info": {
    "name": "API de Filmes",
    "description": "Collection para testar a API de Filmes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Listar todos os filmes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/movies",
          "host": ["{{baseUrl}}"],
          "path": ["movies"]
        }
      }
    },
    {
      "name": "Listar filmes com filtro por gênero",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/movies?gênero=Drama",
          "host": ["{{baseUrl}}"],
          "path": ["movies"],
          "query": [
            {
              "key": "gênero",
              "value": "Drama"
            }
          ]
        }
      }
    },
    {
      "name": "Listar filmes ordenados por título",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/movies?ordem=título",
          "host": ["{{baseUrl}}"],
          "path": ["movies"],
          "query": [
            {
              "key": "ordem",
              "value": "título"
            }
          ]
        }
      }
    },
    {
      "name": "Listar filmes ordenados por nota",
      "request": {
        "method": "GET",
        "header": [],
